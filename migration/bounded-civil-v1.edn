{:schema "kotoba-cron-migration/v1"
 :profile :cron/bounded-civil-v1
 :legacy {:calendar-source "src/cron/execute.cljc"
          :parse-and-validate "src/cron/model.cljc, src/cron/validate.cljc"
          :status :retained-general-oracle}
 :canonical {:engine-and-conformance "src/cron/bounded_civil.kotoba"}
 :domain
 {:functions [:days-from-civil :civil-year :civil-month :civil-day :weekday]
  :algorithm "Howard Hinnant's days_from_civil / civil_from_days, proleptic
             Gregorian calendar (https://howardhinnant.github.io/date_algorithms.html)"
  :scope "Only the pure calendar-arithmetic functions from cron.execute --
         days-from-civil/civil-from-days/weekday -- which have no
         dependency on cron expression parsing at all."}
 :excluded [:cron-expression-parsing :cron-field-sets :fires-at? :next-fire
            :cron-validation]
 :exclusion-reason "cron.model/parse needs regex (kotoba-lang/compiler has
                    no regex/substring-search primitive, filed as part of
                    the kotoba-lang/search finding) and produces field sets
                    up to 60 members (minute 0..59), exceeding the
                    compiler's typed-set-item-limit of 32. fires-at?/
                    next-fire both consume that parsed structure, so they
                    inherit the same blocker. Only the calendar arithmetic
                    underneath is independently portable."
 :compiler-findings
 {:self-shadowing-let-binding-miscompiles-to-js
  {:description "(let [y (if ... y)] ...) -- a let binding whose own value
                 expression references a same-named enclosing binding
                 (the function parameter here), which is valid and
                 idiomatic in Clojure (the outer y is visible while
                 computing the new y) -- compiles to a JS `const k$y=(()=>{
                 ...k$y...})()` where the inner reference resolves to the
                 new (not-yet-initialized) const due to JS temporal-dead-
                 zone rules instead of the outer parameter, throwing
                 \"Cannot access 'k$y' before initialization\" at runtime.
                 Reproduced with a two-line minimal function; only the
                 js-browser target is affected (never reached wasm32-browser
                 to test, since the js repro was decisive and simply
                 renaming avoids the pattern entirely)."
   :compiler-sha "def5161be96d489539175813326a316da46268be"
   :resolution "renamed the shadowing let-binding (y -> y1) in
               days-from-civil; no other function in this profile
               happened to self-shadow a parameter name"}}
 :verification
 {:legacy {:tests 17 :assertions 46 :failures 0 :errors 0}
  :hand-verified-cases
  "7 cases cross-checked against Python's independent datetime module
   before compiling: 1970-01-01 (epoch), 2000-01-01, 2024-02-29 (leap day),
   1969-12-31 and 1900-03-01 and 1600-02-29 (negative day-numbers,
   exercising weekday's floor-mod path), 2026-07-23. Each case checks
   days-from-civil, weekday, and the civil-from-days round-trip
   (civil-year/civil-month/civil-day) all agree."
  :web {:main 42 :required-capabilities []}
  :wasm {:main 42}
  :required-capabilities []
  :local-verification
  {:clojure-test {:tests 17 :assertions 46 :failures 0 :errors 0}
   :lint {:errors 0 :warnings 2 :warnings-note "pre-existing, unrelated to this change (clojure.string require warning in model.cljc, unused-require warning in validate.cljc -- neither file touched by this migration)"}
   :kotoba-compile [:js-browser :wasm32-browser]
   :kotoba-conformance :passed-both-targets}}
 :cutover {:bounded-profile-authorized true :general-cljc-oracle-retained true}}
